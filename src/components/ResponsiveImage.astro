---
// Renders a remote image (typically from media.arbetarorkestern.klokie.com)
// via Cloudflare Image Transformations for responsive variants.
//
// The /cdn-cgi/image/<opts>/<src> path is served by Cloudflare on the current
// zone (klokie.com). Source URL must be publicly fetchable.

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  maxWidth?: number;
  sizes?: string;
  widths?: number[];
  quality?: number;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  maxWidth = 1200,
  sizes = `(max-width: 720px) 100vw, ${maxWidth}px`,
  widths = [400, 640, 800, 1200, 1600],
  quality = 85,
  loading = "lazy",
  fetchpriority,
  class: className,
} = Astro.props;

const cf = (w: number) =>
  `/cdn-cgi/image/width=${w},quality=${quality},format=auto,fit=scale-down/${src}`;

const srcset = widths.map((w) => `${cf(w)} ${w}w`).join(", ");
const fallback = cf(Math.min(maxWidth, Math.max(...widths)));
---

<img
  src={fallback}
  srcset={srcset}
  sizes={sizes}
  alt={alt}
  width={width}
  height={height}
  loading={loading}
  fetchpriority={fetchpriority}
  decoding="async"
  class={className}
/>
