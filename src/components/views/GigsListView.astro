---
import { getCollection } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout.astro";
import GigCard from "@/components/GigCard.astro";
import { siteConfig } from "@/site/config";
import { t } from "@/i18n/ui";
import { dateLocale, localizeUrl, localizedEntries, type Locale } from "@/i18n";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;

const all = localizedEntries(
  await getCollection("gigs", ({ data }) => data.published),
  lang,
).sort((a, b) => a.entry.data.date.getTime() - b.entry.data.date.getTime());
const now = Date.now();
const upcoming = all.filter(
  ({ entry }) => entry.data.date.getTime() >= now && entry.data.status !== "past",
);
const past = all
  .filter(({ entry }) => entry.data.date.getTime() < now || entry.data.status === "past")
  .reverse();
---

<SiteLayout lang={lang} title={t(lang, "gigs.title")} description={t(lang, "gigs.metaDesc")}>
  <section class="container">
    <h1>{t(lang, "gigs.title")}</h1>
    <h2>{t(lang, "gigs.upcoming")}</h2>
    {upcoming.length === 0 ? (
      <p class="muted">{t(lang, "gigs.empty")}</p>
    ) : (
      <div class="grid">
        {upcoming.map(({ slug, entry }) => (
          <a class="card-link" href={localizeUrl(`${siteConfig.paths.gigs}/${slug}`, lang)}>
            <GigCard
              title={entry.data.title}
              date={entry.data.date}
              venue={entry.data.venue}
              city={entry.data.city}
              status={entry.data.status}
              ctaLabel={entry.data.ctaLabel ?? t(lang, "gig.tickets")}
              locale={dateLocale[lang]}
              image={entry.data.image}
              imageAlt={entry.data.imageAlt}
              imageWidth={entry.data.imageWidth}
              imageHeight={entry.data.imageHeight}
            />
          </a>
        ))}
      </div>
    )}

    {past.length > 0 && (
      <>
        <h2>{t(lang, "gigs.past")}</h2>
        <div class="grid">
          {past.map(({ slug, entry }) => (
            <a class="card-link" href={localizeUrl(`${siteConfig.paths.gigs}/${slug}`, lang)}>
              <GigCard
                title={entry.data.title}
                date={entry.data.date}
                venue={entry.data.venue}
                city={entry.data.city}
                status="past"
                locale={dateLocale[lang]}
                image={entry.data.image}
                imageAlt={entry.data.imageAlt}
                imageWidth={entry.data.imageWidth}
                imageHeight={entry.data.imageHeight}
              />
            </a>
          ))}
        </div>
      </>
    )}
  </section>
</SiteLayout>

<style>
  .container { max-width: 720px; margin: 0 auto; padding: 48px 24px; }
  h1 {
    font-family: var(--font-display);
    font-size: 44px;
    letter-spacing: 0.01em;
    margin-bottom: 24px;
  }
  h2 {
    font-family: var(--font-display);
    font-size: 24px;
    letter-spacing: 0.01em;
    margin: 32px 0 16px;
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 600px) {
    .grid { grid-template-columns: 1fr 1fr; }
  }
  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 120ms ease;
  }
  .card-link:hover { transform: translateY(-2px); }
</style>
