---
import { getCollection } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { siteConfig } from "@/site/config";

const all = (await getCollection("videos", ({ data }) => data.published))
  .map((entry) => {
    const primaryDate = entry.data.recordedAt ?? entry.data.date;
    return { entry, primaryDate };
  })
  .sort((a, b) => b.primaryDate.getTime() - a.primaryDate.getTime());

const dateFmt = (d: Date) =>
  d.toLocaleDateString(siteConfig.locale, { day: "numeric", month: "long", year: "numeric" });
---

<SiteLayout title="Media" description="Videoinspelningar från Arbetarorkestern">
  <section class="container">
    <h1>Media</h1>
    {all.length === 0 ? (
      <p class="muted">Inga videor ännu.</p>
    ) : (
      <div class="grid">
        {all.map(({ entry, primaryDate }) => (
          <a class="card" href={`${siteConfig.paths.media}/${entry.id}`}>
            <button
              type="button"
              class="thumb"
              data-video-id={entry.data.videoId}
              aria-label={`Spela ${entry.data.title}`}
            >
              <img
                src={`https://i.ytimg.com/vi/${entry.data.videoId}/hqdefault.jpg`}
                alt=""
                loading="lazy"
                decoding="async"
                width="480"
                height="360"
              />
              <span class="play" aria-hidden="true">
                <svg viewBox="0 0 68 48" width="68" height="48">
                  <path d="M66.5 7.7a8 8 0 0 0-5.6-5.7C56 .7 34 .7 34 .7s-22 0-26.9 1.3A8 8 0 0 0 1.5 7.7C.2 12.7.2 24 .2 24s0 11.3 1.3 16.3a8 8 0 0 0 5.6 5.7C12 47.3 34 47.3 34 47.3s22 0 26.9-1.3a8 8 0 0 0 5.6-5.7C67.8 35.3 67.8 24 67.8 24s0-11.3-1.3-16.3z" fill="#212121" fill-opacity=".75"/>
                  <path d="M27 34l18-10-18-10v20z" fill="#fff"/>
                </svg>
              </span>
            </button>
            <div class="meta">
              <h2 class="title">{entry.data.title}</h2>
              <time datetime={primaryDate.toISOString()}>{dateFmt(primaryDate)}</time>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</SiteLayout>

<script>
  // Click-to-load: clicking the thumbnail injects the YouTube iframe in place,
  // with autoplay set so playback starts immediately. The card <a> is suppressed
  // when the play button is clicked, so the user stays on /media. Clicking
  // anywhere else on the card still navigates to the detail page.
  document.querySelectorAll<HTMLElement>(".thumb").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      const id = btn.getAttribute("data-video-id");
      if (!id) return;
      const iframe = document.createElement("iframe");
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&modestbranding=1&rel=0&playsinline=1`;
      iframe.title = btn.getAttribute("aria-label") || "YouTube";
      iframe.allow = "autoplay; encrypted-media; picture-in-picture; fullscreen";
      iframe.allowFullscreen = true;
      iframe.loading = "eager";
      iframe.referrerPolicy = "strict-origin-when-cross-origin";
      btn.replaceWith(iframe);
      iframe.classList.add("thumb-frame");
    });
  });
</script>

<style>
  .container { max-width: 1040px; margin: 0 auto; padding: 48px 24px; }
  h1 {
    font-family: var(--font-display);
    font-size: 44px;
    letter-spacing: 0.01em;
    margin-bottom: 24px;
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px 20px;
  }
  @media (min-width: 640px) { .grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 960px) { .grid { grid-template-columns: 1fr 1fr 1fr; } }

  .card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }
  .thumb,
  .thumb-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
    border: 0;
    padding: 0;
    border-radius: var(--radius-card, 4px);
    overflow: hidden;
    cursor: pointer;
    display: block;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 200ms ease;
  }
  .thumb:hover img { transform: scale(1.02); }
  .play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .play svg {
    transition: transform 120ms ease;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.4));
  }
  .thumb:hover .play svg { transform: scale(1.06); }
  .thumb-frame { border: 0; }

  .meta { display: flex; flex-direction: column; gap: 4px; }
  .title {
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1.25;
    letter-spacing: 0.01em;
    color: var(--text);
    margin: 0;
  }
  .meta time {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 600;
  }
</style>
