---
import { getCollection, render } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { siteConfig } from "@/site/config";

export async function getStaticPaths() {
  const items = await getCollection("videos", ({ data }) => data.published);
  return items.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, videoId, date, uploadedAt, recordedAt, duration } = entry.data;

const primaryDate = recordedAt ?? date;
const fmt = (d: Date) =>
  d.toLocaleDateString(siteConfig.locale, { day: "numeric", month: "long", year: "numeric" });
const primaryLabel = fmt(primaryDate);
const uploadDate = uploadedAt ?? date;
const showUploadLine = recordedAt && uploadDate.getTime() !== recordedAt.getTime();

const mm = duration ? Math.floor(duration / 60) : 0;
const ss = duration ? String(duration % 60).padStart(2, "0") : "";
const durLabel = duration ? `${mm}:${ss}` : "";

const embedUrl = `https://www.youtube-nocookie.com/embed/${videoId}?modestbranding=1&rel=0&playsinline=1`;
---

<SiteLayout title={title} description={`Video från Arbetarorkestern — ${primaryLabel}`}>
  <article class="container">
    <div class="meta">
      <time datetime={primaryDate.toISOString()}>{primaryLabel}</time>
      {durLabel && <span class="dot">·</span>}
      {durLabel && <span class="dur">{durLabel}</span>}
    </div>
    <h1>{title}</h1>

    <div class="player">
      <iframe
        src={embedUrl}
        title={title}
        loading="lazy"
        allow="encrypted-media; picture-in-picture; fullscreen"
        allowfullscreen
        referrerpolicy="strict-origin-when-cross-origin"
      ></iframe>
    </div>

    {showUploadLine && (
      <p class="upload">Publicerad på YouTube {fmt(uploadDate)}.</p>
    )}

    <div class="prose">
      <Content />
    </div>

    <p class="external">
      <a href={`https://www.youtube.com/watch?v=${videoId}`} rel="noopener" target="_blank">
        → Öppna på YouTube
      </a>
    </p>
    <p class="back"><a href={siteConfig.paths.media}>← Alla videor</a></p>
  </article>
</SiteLayout>

<style>
  .container { max-width: 880px; margin: 0 auto; padding: 48px 24px; }
  .meta {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 600;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .meta .dot { opacity: 0.6; }
  h1 {
    font-family: var(--font-display);
    font-size: 36px;
    letter-spacing: 0.01em;
    line-height: 1.15;
    margin-bottom: 24px;
  }
  .player {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
    background: #000;
    border-radius: var(--radius-card, 4px);
    overflow: hidden;
    margin-bottom: 16px;
  }
  .player iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .upload {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--muted);
    margin: 0 0 24px;
  }
  .prose :global(p) {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--text);
    line-height: 1.65;
    margin-bottom: 1em;
  }
  .prose :global(a) { color: var(--primary); }
  .external {
    margin-top: 24px;
    font-family: var(--font-body);
    font-size: 14px;
  }
  .external a { color: var(--primary); }
  .back {
    margin-top: 48px;
    font-family: var(--font-body);
    font-size: 14px;
  }
  .back a { color: var(--muted); }
</style>
