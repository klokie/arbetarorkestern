---
import { getCollection } from "astro:content";
import GigDetailView from "@/components/views/GigDetailView.astro";
import { localizedEntries } from "@/i18n";

export async function getStaticPaths() {
  const all = await getCollection("gigs", ({ data }) => data.published);
  return localizedEntries(all, "sv").map(({ slug, entry }) => ({
    params: { slug },
    props: { entry },
  }));
}
const { entry } = Astro.props;
---

<GigDetailView lang="sv" entry={entry} />
