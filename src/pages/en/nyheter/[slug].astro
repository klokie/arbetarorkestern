---
import { getCollection } from "astro:content";
import NewsArticleView from "@/components/views/NewsArticleView.astro";
import { localizedEntries } from "@/i18n";

export async function getStaticPaths() {
  const all = await getCollection("news", ({ data }) => data.published);
  return localizedEntries(all, "en").map(({ slug, entry }) => ({
    params: { slug },
    props: { entry },
  }));
}
const { entry } = Astro.props;
---

<NewsArticleView lang="en" entry={entry} />
