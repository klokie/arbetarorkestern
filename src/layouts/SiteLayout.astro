---
import BaseLayout from "@klokie/theme/layouts/BaseLayout.astro";
import SiteHeader from "@klokie/theme/components/SiteHeader.astro";
import SiteFooter from "@klokie/theme/components/SiteFooter.astro";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import "@klokie/theme/tokens/jordsang.css";
import { siteConfig } from "@/site/config";
import { t } from "@/i18n/ui";
import { locales, defaultLocale, localizeUrl, localePaths, type Locale } from "@/i18n";

interface Props {
  lang?: Locale;
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogType?: "website" | "article" | "event" | "profile";
  jsonLd?: object | object[];
  noindex?: boolean;
  canonicalUrl?: string;
}
const {
  lang = defaultLocale,
  title,
  description,
  ogImage,
  ogImageAlt,
  ogImageWidth,
  ogImageHeight,
  ogType = "website",
  jsonLd,
  noindex = false,
  canonicalUrl,
} = Astro.props;

const tagline = t(lang, "site.tagline");
const fullTitle = title ? `${title} — ${siteConfig.title}` : siteConfig.title;
const fullDescription = description ?? t(lang, "site.description");

const origin = Astro.site ?? Astro.url.origin;
const abs = (p: string) => new URL(p, origin).href;
const paths = localePaths(Astro.url.pathname);
const canonical = canonicalUrl ?? abs(Astro.url.pathname);

const ogLocaleMap: Record<Locale, string> = { sv: "sv_SE", en: "en_US" };
const ogLocale = ogLocaleMap[lang];
const ogLocaleAlternates = locales.filter((l) => l !== lang).map((l) => ogLocaleMap[l]);

// Localized primary nav (the language switcher is rendered separately, in the
// header's nav-end slot).
const navItems = siteConfig.nav.map((item) => ({
  label: t(lang, item.key),
  href: localizeUrl(item.path, lang),
}));

// Pages without their own poster (home, listings, about) fall back to the
// site-wide branded card so link previews always have an image.
const usingDefaultOg = !ogImage;
const resolvedOgImage = ogImage ?? abs("/og-default.png");
const resolvedOgImageAlt =
  ogImageAlt ?? (usingDefaultOg ? `${siteConfig.title} – ${tagline}` : undefined);
const resolvedOgImageWidth = usingDefaultOg ? 1200 : ogImageWidth;
const resolvedOgImageHeight = usingDefaultOg ? 630 : ogImageHeight;

const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
// Escape `</script>` and other unsafe sequences in JSON-LD to prevent
// breaking out of the <script> tag.
const serializeJsonLd = (obj: object) =>
  JSON.stringify(obj)
    .replace(/</g, "\\u003c")
    .replace(/>/g, "\\u003e")
    .replace(/&/g, "\\u0026");
---

<BaseLayout
  title={fullTitle}
  description={fullDescription}
  preset={siteConfig.preset}
  ogImage={resolvedOgImage}
  lang={lang}
>
  <Fragment slot="head">
    <link rel="canonical" href={canonical} />
    {locales.map((l) => (
      <link rel="alternate" hreflang={l} href={abs(paths[l])} />
    ))}
    <link rel="alternate" hreflang="x-default" href={abs(paths[defaultLocale])} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlternates.map((l) => (
      <meta property="og:locale:alternate" content={l} />
    ))}
    <meta property="og:url" content={canonical} />
    {resolvedOgImageAlt && <meta property="og:image:alt" content={resolvedOgImageAlt} />}
    {resolvedOgImageWidth && <meta property="og:image:width" content={String(resolvedOgImageWidth)} />}
    {resolvedOgImageHeight && <meta property="og:image:height" content={String(resolvedOgImageHeight)} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={fullDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />
    {resolvedOgImageAlt && <meta name="twitter:image:alt" content={resolvedOgImageAlt} />}
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {jsonLdArray.map((obj) => (
      <script type="application/ld+json" is:inline set:html={serializeJsonLd(obj)} />
    ))}
  </Fragment>
  <SiteHeader
    title={siteConfig.title}
    tagline={tagline}
    monogram={siteConfig.monogram}
    nav={navItems}
    homeHref={localizeUrl("/", lang)}
  >
    <LanguageSwitcher slot="nav-end" lang={lang} pathname={Astro.url.pathname} />
  </SiteHeader>
  <main>
    <slot />
  </main>
  <SiteFooter
    copyrightName={siteConfig.copyrightName}
    social={siteConfig.social}
    credit={{ label: "Made with ❤️ by Klokie.com", href: "https://klokie.com" }}
  />
</BaseLayout>
